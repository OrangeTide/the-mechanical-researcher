#!/bin/sh
# term-screenshot : render CLI output with ANSI colors as an SVG terminal
# Copyright (c) 2026 — MIT-0 OR Public Domain
# Written with AI assistance (Claude, Anthropic)
#
# Usage:
#   term-screenshot [-t title] [-w width] [-o file] [command args...]
#   some-command | term-screenshot [-t title] [-w width] [-o file]
#
# If a command is given, it is run with CLICOLOR_FORCE=1 and its
# combined stdout+stderr is captured. Otherwise reads from stdin.
#
# Output goes to stdout unless -o is given.
#
# Examples:
#   term-screenshot -t "Build" -o build.svg make
#   ls --color=always | term-screenshot -o listing.svg
#   term-screenshot -t "Demo" -o demo.svg sh -c './server & sleep 1; ./client'

set -e

TITLE="Terminal"
WIDTH=760
OUTFILE=""

while getopts "t:w:o:" opt; do
    case "$opt" in
        t) TITLE="$OPTARG" ;;
        w) WIDTH="$OPTARG" ;;
        o) OUTFILE="$OPTARG" ;;
        *) echo "Usage: term-screenshot [-t title] [-w width] [-o file] [command...]" >&2; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

DIR=$(mktemp -d)
trap 'rm -rf "$DIR"' EXIT

# Capture input
if [ $# -gt 0 ]; then
    export CLICOLOR_FORCE=1
    "$@" > "$DIR/raw" 2>&1 || true
else
    cat > "$DIR/raw"
fi

# Convert ANSI escape sequences to SVG tspan elements with CSS classes.
# Handles: ESC[0m (reset), ESC[1m (bold), ESC[31-37m (colors),
# ESC[1;32m combos, ESC[K (clear line), ESC[90-97m (bright colors)
ansi_to_svg() {
    sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g' | awk '
    BEGIN { cls = "t" }
    {
        line = $0
        result = ""
        while (match(line, /\033\[[0-9;]*[mK]/)) {
            pre = substr(line, 1, RSTART - 1)
            code = substr(line, RSTART, RLENGTH)
            line = substr(line, RSTART + RLENGTH)

            if (pre != "")
                result = result "<tspan class=\"" cls "\">" pre "</tspan>"

            if (code ~ /\[0m/) {
                cls = "t"
            } else if (code ~ /\[1;31m/ || code ~ /\[31;1m/) {
                cls = "red-bold"
            } else if (code ~ /\[1;32m/ || code ~ /\[32;1m/) {
                cls = "green-bold"
            } else if (code ~ /\[1;33m/ || code ~ /\[33;1m/) {
                cls = "yellow-bold"
            } else if (code ~ /\[1;34m/ || code ~ /\[34;1m/) {
                cls = "blue-bold"
            } else if (code ~ /\[1;35m/ || code ~ /\[35;1m/) {
                cls = "magenta-bold"
            } else if (code ~ /\[1;36m/ || code ~ /\[36;1m/) {
                cls = "cyan-bold"
            } else if (code ~ /\[1m/) {
                if (cls == "green") cls = "green-bold"
                else if (cls == "red") cls = "red-bold"
                else if (cls == "yellow") cls = "yellow-bold"
                else if (cls == "blue") cls = "blue-bold"
                else if (cls == "magenta") cls = "magenta-bold"
                else if (cls == "cyan") cls = "cyan-bold"
                else cls = "bold"
            } else if (code ~ /\[31m/ || code ~ /\[91m/) {
                cls = "red"
            } else if (code ~ /\[32m/ || code ~ /\[92m/) {
                if (cls == "bold") cls = "green-bold"
                else cls = "green"
            } else if (code ~ /\[33m/ || code ~ /\[93m/) {
                cls = "yellow"
            } else if (code ~ /\[34m/ || code ~ /\[94m/) {
                cls = "blue"
            } else if (code ~ /\[35m/ || code ~ /\[95m/) {
                cls = "magenta"
            } else if (code ~ /\[36m/ || code ~ /\[96m/) {
                cls = "cyan"
            } else if (code ~ /\[37m/ || code ~ /\[97m/) {
                cls = "t"
            }
        }
        if (line != "")
            result = result "<tspan class=\"" cls "\">" line "</tspan>"
        print result
    }'
}

# Convert raw capture to SVG spans
ansi_to_svg < "$DIR/raw" > "$DIR/spans"
total_lines=$(wc -l < "$DIR/spans")
height=$((40 + total_lines * 22 + 16))

# Title needs XML escaping
xml_title=$(printf '%s' "$TITLE" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g')

# Generate SVG
{
cat << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="$WIDTH" height="$height">
  <style>
    text { font-family: ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, Consolas, monospace; font-size: 13px; white-space: pre; }
    .bg { fill: #1e1e2e; }
    .titlebar { fill: #313244; }
    .title { fill: #cdd6f4; }
    .t { fill: #cdd6f4; }
    .bold { fill: #cdd6f4; font-weight: bold; }
    .red { fill: #f38ba8; }
    .red-bold { fill: #f38ba8; font-weight: bold; }
    .green { fill: #a6e3a1; }
    .green-bold { fill: #a6e3a1; font-weight: bold; }
    .yellow { fill: #f9e2af; }
    .yellow-bold { fill: #f9e2af; font-weight: bold; }
    .blue { fill: #89b4fa; }
    .blue-bold { fill: #89b4fa; font-weight: bold; }
    .magenta { fill: #cba6f7; }
    .magenta-bold { fill: #cba6f7; font-weight: bold; }
    .cyan { fill: #94e2d5; }
    .cyan-bold { fill: #94e2d5; font-weight: bold; }
  </style>
  <rect class="bg" width="$WIDTH" height="$height" rx="8"/>
  <rect class="titlebar" width="$WIDTH" height="32" rx="8"/>
  <rect class="bg" x="0" y="24" width="$WIDTH" height="8"/>
  <circle cx="20" cy="16" r="6" fill="#f38ba8"/>
  <circle cx="40" cy="16" r="6" fill="#f9e2af"/>
  <circle cx="60" cy="16" r="6" fill="#a6e3a1"/>
  <text class="title" x="$(( WIDTH / 2 ))" y="20" text-anchor="middle">$xml_title</text>
SVGEOF

y=56
while IFS= read -r span; do
    printf '  <text y="%d" x="16">%s</text>\n' "$y" "$span"
    y=$((y + 22))
done < "$DIR/spans"

echo '</svg>'

} > "$DIR/out.svg"

if [ -n "$OUTFILE" ]; then
    cp "$DIR/out.svg" "$OUTFILE"
    echo "Generated $OUTFILE ($total_lines lines, ${height}px)" >&2
else
    cat "$DIR/out.svg"
fi
